# Opción 1 (recomendada): URL completa de MySQL
MYSQL_URL=mysql://usuario:contraseña@host:3306/Taller_MoTor?ssl-mode=REQUIRED

# Opción 2: variables individuales de MySQL
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=contraseña
# DB_NAME=Taller_MoTor

# JWT Secret (cambiar por un valor seguro)
JWT_SECRET=pon_aqui_un_secreto_muy_largo_y_seguro

# APP_PORT (Railway asigna PORT automáticamente)
APP_PORT=3001
